# REAPA Environment Variables
# Copy this file to .env.local and fill in your values

# ======================
# SUPABASE (Required for database)
# Get these from: https://app.supabase.com -> Project Settings -> API
# ======================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ======================
# AI APIs (Required for AI features)
# ======================

# Gemini 2.0 Flash - Primary AI (https://ai.google.dev/gemini-api/docs)
GEMINI_API_KEY=your-gemini-api-key

# Groq - Fallback + Speed tasks (https://console.groq.com)
GROQ_API_KEY=your-groq-api-key

# DeepSeek - AML/Compliance reasoning (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your-deepseek-api-key

# ======================
# APP CONFIG
# ======================
NEXT_PUBLIC_APP_URL=https://reapa-mvp.vercel.app
NEXT_PUBLIC_APP_NAME=REAPA

# ======================
# OPTIONAL INTEGRATIONS
# ======================

# Stripe (billing - Phase 2)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SendGrid (email notifications)
SENDGRID_API_KEY=SG.xxx

# Twilio (WhatsApp/SMS)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+356xxx