# ─────────────────────────────────────────────────────────────────
# REAPA MVP — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# Set production values in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── Supabase (required for auth + real data) ──────────────────────
# Create project: https://supabase.com → New project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma connection (same Supabase project, use Transaction pooler for serverless)
# Session pooler for direct connections, Transaction pooler for serverless/edge
DATABASE_URL=postgresql://postgres.PROJECT_ID:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT_ID:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── AI Providers ──────────────────────────────────────────────────
# Gemini 2.0 Flash (primary, generous free tier): https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key


# Optional API key to protect /api/ai/chat in production (any string you choose)
# Leave empty to allow open access (rate limiting still applies)
REAPA_API_KEY=

# ── Analytics ─────────────────────────────────────────────────────
# PostHog EU (1M events/month free): https://eu.posthog.com/
NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Google Analytics 4 (free): https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Notion (waitlist database — optional) ─────────────────────────
NOTION_API_KEY=secret_your-notion-integration-key
NOTION_WAITLIST_DB_ID=your-notion-database-id
