// REAPA — Prisma Schema
// Mirrors Supabase PostgreSQL schema in src/db/schema.sql
// Run: npx prisma db push  (dev)
//      npx prisma migrate deploy  (prod)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agent {
  id                String    @id @default(cuid())
  email             String    @unique
  fullName          String    @map("full_name")
  agencyName        String?   @map("agency_name")
  city              String    @default("Malta")
  language          String    @default("en")
  timezone          String    @default("Europe/Malta")
  subscriptionTier  String    @default("free") @map("subscription_tier")
  leads             Lead[]
  clients           Client[]
  tasks             Task[]
  listings          Listing[]
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("agents")
}

model Lead {
  id                  String   @id @default(cuid())
  agentId             String   @map("agent_id")
  agent               Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  firstName           String   @map("first_name")
  lastName            String   @map("last_name")
  email               String?
  phone               String?
  status              LeadStatus @default(NEW)
  propertyType        String?  @map("property_type")
  budgetMin           Float?   @map("budget_min")
  budgetMax           Float?   @map("budget_max")
  preferredLocations  String[] @map("preferred_locations")
  notes               String?  @db.Text
  score               Int      @default(0)
  source              String?
  tasks               Task[]
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([status])
  @@map("leads")
}

model Client {
  id          String       @id @default(cuid())
  agentId     String       @map("agent_id")
  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  firstName   String       @map("first_name")
  lastName    String       @map("last_name")
  email       String?
  phone       String?
  type        ClientType
  status      ClientStatus @default(ACTIVE)
  nationality String?
  notes       String?      @db.Text
  tasks       Task[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([agentId])
  @@map("clients")
}

model Listing {
  id            String        @id @default(cuid())
  agentId       String        @map("agent_id")
  agent         Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title         String
  description   String?       @db.Text
  propertyType  String        @map("property_type")
  transactionType String      @map("transaction_type")
  price         Float
  areaSqm       Float?        @map("area_sqm")
  bedrooms      Int?
  bathrooms     Int?
  location      String
  address       String?
  status        ListingStatus @default(ACTIVE)
  epcRating     String?       @map("epc_rating")
  imageUrls     String[]      @map("image_urls")
  tasks         Task[]
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([status])
  @@map("listings")
}

model Task {
  id          String       @id @default(cuid())
  agentId     String       @map("agent_id")
  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  leadId      String?      @map("lead_id")
  lead        Lead?        @relation(fields: [leadId], references: [id])
  clientId    String?      @map("client_id")
  client      Client?      @relation(fields: [clientId], references: [id])
  listingId   String?      @map("listing_id")
  listing     Listing?     @relation(fields: [listingId], references: [id])
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

model ComplianceRecord {
  id                String   @id @default(cuid())
  agentId           String   @map("agent_id")
  leadId            String?  @map("lead_id")
  clientId          String?  @map("client_id")
  type              String   // aml_check, kyc, fiau_report, epc, konvenju
  status            String   @default("pending")
  documentUrls      String[] @map("document_urls")
  notes             String?  @db.Text
  expiresAt         DateTime? @map("expires_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@map("compliance_records")
}

enum LeadStatus {
  NEW
  HOT
  WARM
  COLD
  ICE
  CLOSED_WON
  CLOSED_LOST
}

enum ClientType {
  BUYER
  SELLER
  LANDLORD
  TENANT
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ListingStatus {
  ACTIVE
  UNDER_OFFER
  SOLD
  RENTED
  OFF_MARKET
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
