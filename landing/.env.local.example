# REAPA Landing Page — Environment Variables

# Notion API Key (Internal Integration token)
# Get from: https://www.notion.so/profile/integrations → New integration
# Then share the "REAPA Waitlist" database with the integration
NOTION_API_KEY=secret_your_notion_internal_integration_token

# Pre-configured Notion Waitlist DB ID (do not change)
# Notion DB: https://www.notion.so/34451e3c53a481d0a922ec45ab0cf6c4
NOTION_WAITLIST_DB_ID=34451e3c-53a4-81d0-a922-ec45ab0cf6c4
